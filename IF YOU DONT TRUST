using System.Linq.Expressions;
using System.Net.Http.Json;

namespace worker
{
    public class Job
    {
        public Guid Id { get; set; }
        public required string Input { get; set; }
        public string? Status { get; set; }

        public string Result { get; set; } = "";
    }

    public class Program
    {

        public static async Task Main(string[] args)
        {
            string? url; 
            url = "https://localhost:7043/jobs/next";

            HttpClient client = new HttpClient();

            //work loop
            while(true)
            {
                try
                {
                    Job? job = await client.GetFromJsonAsync<Job>(url);
                    
                    string result = "";

                    var token = new CancellationTokenSource();

                    var updateTask = Update(result, job, client, token);

                    result = Work(job);

                    token.Cancel();
                    await updateTask;

                    string urlPost = "https://localhost:7043/jobs/";

                    job.Result = result;

                    urlPost = urlPost + job.Id + "/complete";
                    await client.PostAsJsonAsync(urlPost, job);
                    await Task.Delay(5000);
                }
                catch (Exception ex)
                {
                    await Task.Delay(5000);
                }
            }
        }

        public static String Work(Job job)
        {
            string input = job.Input;
            string result = "";
            for (int i = 0; i < input.Length; i++)
            {
                result = input[i] + result;
            }
            return result;
        }

        public static async Task Update(string result, Job job, HttpClient client, CancellationTokenSource token)
        {
            while(!token.IsCancellationRequested)
            {
                string url = $"https://localhost:7043/jobs/{job.Id}/update";
                await client.PostAsync(url, JsonContent.Create(job.Id));
                await Task.Delay(5000);
            }
        }
    }
}





