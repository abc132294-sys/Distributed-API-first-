using Scalar.AspNetCore;
using System.Text.Json;
using System.Net.Http.Json;
using System.Threading.Tasks;
using System.Collections.Concurrent;

namespace multi_work_job_api
{

    public class Job
    {
        public Guid Id { get; set; }
        public required string Input { get; set; }
        public string? Status { get; set; }

        public string Result { get; set; } = "";
        public DateTime Update { get; set; } = DateTime.Now;
        public int Attempts { get; set; } = 0;
    }

    public class Program
    {

        public readonly static object _fileLock = new();

        private static Task Main(string[] args)
        {

            ConcurrentDictionary<Guid, Job> jobs = new ConcurrentDictionary<Guid, Job>();
            ConcurrentQueue<Guid> jobQueue = new ConcurrentQueue<Guid>();

            var jsonJobs = Path.Combine(AppContext.BaseDirectory, "jobs.json");
            var jsonQueue = Path.Combine(AppContext.BaseDirectory, "queue.json");

            //Checks if there are any saved jobs and queues, if so it loads them
            if (File.Exists(jsonJobs))
            {
                string ba = File.ReadAllText(jsonJobs);
                if (!string.IsNullOrWhiteSpace(ba))
                {
                    jobs.Clear();
                    jobs = JsonSerializer.Deserialize<ConcurrentDictionary<Guid, Job>>(File.ReadAllText(jsonJobs)) ?? new ConcurrentDictionary<Guid, Job>();

                    jobQueue.Clear();
                    jobQueue = JsonSerializer.Deserialize<ConcurrentQueue<Guid>>(File.ReadAllText(jsonQueue)) ?? new ConcurrentQueue<Guid>();
                }
            }
            else
            {
                File.Create(jsonJobs);
                File.Create(jsonQueue);
            }

            var builder = WebApplication.CreateBuilder(args);

            // Add services to the container.
            // Learn more about configuring OpenAPI at https://aka.ms/aspnet/openapi
            builder.Services.AddOpenApi();

            var app = builder.Build();

            // Configure the HTTP request pipeline.
            if (app.Environment.IsDevelopment())
            {
                app.MapScalarApiReference();
                app.MapOpenApi();
            }

            app.MapPost("/jobs", (string? input) =>
            {
                Guid id = Guid.NewGuid();
                if (string.IsNullOrEmpty(input))
                {
                    return Results.BadRequest("Input cannot be null or empty.");
                }

                Job job = new Job
                {
                    Id = id,
                    Input = input,
                    Status = "Queued"

                };

                jobQueue.Enqueue(id);
                jobs.TryAdd(id, job);

                lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                return Results.Ok(id);
            }).WithName("/CreateJobs");

            app.MapGet("/jobs/{id}", (Guid id) =>
            {
                if (jobs.TryGetValue(id, out Job? job))
                {
                    return Results.Ok(job);
                }
                else
                {
                    return Results.NotFound("Job not found.");
                }
            }).WithName("/GetJob");

            app.MapGet("/jobs/next", async () =>
            {
                if (jobQueue.TryDequeue(out Guid id))
                {
                    jobs[id].Status = "Processing";
                    jobs[id].Update = DateTime.Now;
                    lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                    foreach (var job in jobs.Values)
                    {
                        if (job.Update < DateTime.UtcNow.AddMinutes(-1) && job.Status == "Processing")
                        {
                            job.Status = "Queued";
                            job.Attempts++;
                            jobQueue.Enqueue(job.Id);
                        }
                    }
                    return Results.Ok(jobs[id]);
                }
                else
                {
                    return Results.NoContent();
                }
            }).WithName("/NextJob");

            app.MapPost("/jobs/{id}/complete", async (Job getjob) =>
            {
                try
                {
                    Console.WriteLine("Recieved completion POST from a worker.");
                    Job job = jobs[getjob.Id];
                    if (job.Status == "Completed")
                    {
                        lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                        return Results.BadRequest("Job is already done.");
                    }
                    job.Result = getjob.Result;
                    job.Status = "Completed";
                }
                catch (KeyNotFoundException)
                {
                    lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                    return Results.NotFound("Job not found.");
                }
                lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                return Results.Ok();
            });

            app.MapPost("/jobs/{id}/update", async (Guid id) =>
            {
                Console.WriteLine("Recieved update for a worker.");
                jobs[id].Update = DateTime.Now;
                lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                return Results.Ok();
            });

            app.MapPost("/jobs/{id}/delete", async (Guid id) =>
            {
                if (jobs[id].Status == "Processing") return Results.BadRequest("Cannot delete a job that is being processed.");
                jobs.TryRemove(id, out _);
                lock (_fileLock) { SaveData(jobs, jobQueue, jsonJobs, jsonQueue); }
                return Results.Ok();
            });

            app.UseHttpsRedirection();

            app.Run();

            return Task.CompletedTask;
        }

        public static void SaveData(ConcurrentDictionary<Guid, Job> jobs, ConcurrentQueue<Guid> jobQueue, string jsonJobs, string jsonQueue)
        {

            var fileStreamJobs = new FileStream(jsonJobs, FileMode.Create, FileAccess.Write);
            var fileStreamQueue = new FileStream(jsonQueue, FileMode.Create, FileAccess.Write);

            fileStreamJobs.Write(JsonSerializer.SerializeToUtf8Bytes(jobs));
            fileStreamQueue.Write(JsonSerializer.SerializeToUtf8Bytes(jobQueue.ToList()));

            fileStreamJobs.Flush();
            fileStreamQueue.Flush();

            fileStreamJobs.Dispose();
            fileStreamQueue.Dispose();
        }
    }
}





